# Clerk Publishable Key
# Get yours from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Cardano Network ID
# 0 = Preprod (testnet)
# 1 = Mainnet
VITE_NETWORK_ID=0

# App Domain for wallet derivation
# This is used to derive the wallet's app-specific path
VITE_APP_DOMAIN=demo.web2bridge.local

# Hot Module Replacement (HMR) Configuration (Optional)
# Use these when running dev server behind a reverse proxy
# VITE_HMR_HOST=demo.lan.example.com
# VITE_HMR_PROTOCOL=wss
# VITE_HMR_CLIENT_PORT=443
