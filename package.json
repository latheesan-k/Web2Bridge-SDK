{
  "name": "web2bridge-sdk",
  "private": true,
  "license": "Apache-2.0",
  "author": "Latheesan Kanesamoorthy (https://github.com/latheesan-k)",
  "repository": {
    "type": "git",
    "url": "https://github.com/latheesan-k/Web2Bridge-SDK.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "bufferutil",
      "utf-8-validate"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "18",
        "@types/react": "18",
        "@harmoniclabs/crypto": "0.2",
        "bs58": "5",
        "yaml": "1"
      }
    }
  }
}
